---
import { url } from '../lib/url';
const { product } = Astro.props;
const d = product.data;
const date = d.date instanceof Date ? d.date.toISOString().slice(0, 10) : String(d.date);
const CAT_KO = { beauty: '뷰티', health: '건강', home: '홈' };
const catKo = CAT_KO[d.category] || d.category;
---
<a class="card" href={url(`/products/${product.id}/`)} data-category={d.category}>
  <div class="imgwrap"><img src={url(d.image)} alt={d.title} loading="lazy" /></div>
  <div class="meta">
    <span class="cat"><span class="t-en">{d.category}</span><span class="t-ko">{catKo}</span></span>
    <span class="date">{date}</span>
  </div>
  <h3>{d.title}</h3>
  <span class="view"><span class="t-en">View →</span><span class="t-ko">보기 →</span></span>
</a>
<style>
  .card { display:block; text-decoration:none; color:inherit; border:1px solid var(--line); border-radius:14px; overflow:hidden; transition:box-shadow .15s ease, transform .15s ease; background:#fff; }
  .card:hover { box-shadow:0 8px 24px rgba(0,0,0,.07); transform:translateY(-2px); }
  .imgwrap { aspect-ratio:1/1; background:#f6f6f6; }
  .imgwrap img { width:100%; height:100%; object-fit:cover; }
  .meta { display:flex; justify-content:space-between; font-size:.72rem; color:var(--muted); padding:.65rem .8rem 0; text-transform:lowercase; }
  .card h3 { font-size:.98rem; margin:.3rem .8rem .2rem; line-height:1.3; }
  .view { display:inline-block; margin:0 .8rem 1rem; font-size:.82rem; color:var(--accent); }
</style>
